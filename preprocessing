import pandas as pd

raw_data = pd.read_csv(r'Gestational Diabetic Dat Set.csv')
print(raw_data.info())
print(raw_data['BMI'].isna().sum())

#%% Preprocessing 
# STEP 1: remove nan values to achieve even class numbers 

# There are 483 samples with nan values for BMI and Sys BP 
# Remove the 483 nan values
fil_df = raw_data[~(raw_data['BMI'].isna() & raw_data['Sys BP'].isna())] # ~ negates conditions 

# remove 298 nan values from OGTT so class numbers are equal and removes nan values from OGTT
nan_OGTT = raw_data[raw_data['OGTT'].isna()] #513 
# Randomly sample 298 rows 
rows_to_remove = nan_OGTT.sample(n=298, random_state=42)
# Remove those sampled rows from the dataset
filtered_data = fil_df.drop(rows_to_remove.index)

# check classes are equal 
print((filtered_data['Class Label(GDM /Non GDM)']==0).sum()) 
print((filtered_data['Class Label(GDM /Non GDM)']==1).sum()) # both are 1372 

#check  the nan values are as expected 
cols_with_nan = filtered_data.columns[filtered_data.isna().any()] 
nan_values = filtered_data[cols_with_nan].isna().sum() # numbers are as expected 

# set 'case number' column as index 
dataset = filtered_data.set_index('Case Number')

# STEP 2: check for duplicate rows 
print(dataset.duplicated().sum()) # no duplicates present 

# STEP 3: handle remaining missing values 
# Log reg and NN cannot handle NAN values 
# group-based mean imputation

# Replace columns with NaN with the mean values of the same class label 
dataset_fil = dataset.copy()
dataset_fil['BMI'] = dataset.groupby('Class Label(GDM /Non GDM)').BMI.transform(lambda x: x.fillna(x.mean()))
dataset_fil['HDL'] = dataset.groupby('Class Label(GDM /Non GDM)').BMI.transform(lambda x: x.fillna(x.mean()))
dataset_fil['Sys BP'] = dataset.groupby('Class Label(GDM /Non GDM)').BMI.transform(lambda x: x.fillna(x.mean()))
dataset_fil['OGTT'] = dataset.groupby('Class Label(GDM /Non GDM)').BMI.transform(lambda x: x.fillna(x.mean()))

# check NAN values 
print(dataset_fil.isna().sum())

# STEP 4: assign variables 

y = dataset_fil['Class Label(GDM /Non GDM)']
x = dataset_fil.iloc[:,:-1]

#STEP 5: train test split (train = 70%) 
from sklearn.model_selection import train_test_split
x_train, x_temp, y_train, y_temp = train_test_split(x, y, random_state=42, test_size=0.30, stratify=y)

# assign test and validation sets (both 15%)
x_test, x_val, y_test, y_val = train_test_split(
    x_temp, y_temp,
    test_size=0.50,
    random_state=42,
    stratify=y_temp
)

#%% Pipelines 
# STEP 6: model pipelines with feature scaling, class imbalance and model specific parameters
from sklearn.preprocessing import StandardScaler
from sklearn.pipeline import Pipeline
from sklearn.linear_model import LogisticRegression
from sklearn.ensemble import RandomForestClassifier
from xgboost import XGBClassifier
from sklearn.neural_network import MLPClassifier



log_reg_pipeline = Pipeline(steps=[
    ('standardscaler', StandardScaler()),
    ('logisticregression', LogisticRegression(max_iter=100))
    ])

rf_pipeline = Pipeline(steps=[
    ('standardscaler', StandardScaler()),
    ('randomforest', RandomForestClassifier(n_estimators=100, random_state=42,))
    ])


XG_pipeline = Pipeline(steps=[
    ('XGBoost', XGBClassifier(n_estimators=41, random_state=42, eval_metric="error", early_stopping_rounds=10))
    ])


NN_pipeline = Pipeline(steps=[
    ('standardscaler', StandardScaler()),
    ('neuralnetwork', MLPClassifier(hidden_layer_sizes=(64, 32), early_stopping=True, random_state=42))
    ])




#%% Training the models
from sklearn.metrics import accuracy_score, classification_report


#%% Logistic Regression 
log_reg_pipeline.fit(x_train, y_train)
log_predict = log_reg_pipeline.predict(x_test)

log_proba = log_reg_pipeline.predict_proba(x_test)[:,1] # probability of class 1 (GDM)

log_accuracy = accuracy_score(y_test, log_predict)
log_classification = classification_report(y_test, log_predict)

print(log_accuracy)
print(log_classification)


#%% Random Forest 
rf_pipeline.fit(x_train, y_train)
rf_predict = rf_pipeline.predict(x_test)

rf_accuracy = accuracy_score(y_test, rf_predict)
rf_classification = classification_report(y_test, rf_predict)

print(rf_accuracy)
print(rf_classification)


#%% XGBoost 
# Evaluating model performance during training 

XG_pipeline = Pipeline(steps=[
    ('XGBoost', XGBClassifier(n_estimators=100, random_state=42, eval_metric="logloss", early_stopping_rounds=20))
    ])

XG_pipeline.fit(
    x_train,
    y_train,
    XGBoost__eval_set=[(x_train, y_train), (x_val, y_val)],
    XGBoost__verbose=True
)

XG_predict = XG_pipeline.predict(x_test)

XG_accuracy = accuracy_score(y_test, XG_predict)
XG_classification = classification_report(y_test, XG_predict)

print(XG_accuracy)
print(XG_classification)

# evaluate model performance with validation set 
XG_results = XG_pipeline.named_steps['XGBoost'].evals_result()
epochs = len(XG_results['validation_0']['logloss'])
x_axis = range(0, epochs)

from matplotlib import pyplot as plt

# plot classification error
fig, ax = plt.subplots()
ax.plot(x_axis, XG_results['validation_0']['logloss'], label='Train')
ax.plot(x_axis, XG_results['validation_1']['logloss'], label='Validation')
ax.legend()
plt.ylabel('logloss')
plt.xlabel('Boosting Round')
plt.title('XGBoost Classification Error')
plt.show()



#%% Neural network 
NN_pipeline.fit(x_train, y_train)


