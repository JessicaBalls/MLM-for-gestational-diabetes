import pandas as pd

raw_data = pd.read_csv(r'C:Gestational Diabetic Dat Set.csv')
print(raw_data.info())
print(raw_data['BMI'].isna().sum())

#%% Preprocessing 
# STEP 1: remove nan values to achieve even class numbers 

# There are 483 samples with nan values for BMI and Sys BP 
# Remove the 483 nan values
fil_df = raw_data[~(raw_data['BMI'].isna() & raw_data['Sys BP'].isna())] # ~ negates conditions 

# remove 298 nan values from OGTT so class numbers are equal and removes nan values from OGTT
nan_OGTT = raw_data[raw_data['OGTT'].isna()] #513 
# Randomly sample 298 rows 
rows_to_remove = nan_OGTT.sample(n=298, random_state=42)
# Remove those sampled rows from the dataset
filtered_data = fil_df.drop(rows_to_remove.index)

# check classes are equal 
print((filtered_data['Class Label(GDM /Non GDM)']==0).sum()) 
print((filtered_data['Class Label(GDM /Non GDM)']==1).sum()) # both are 1372 

#check  the nan values are as expected 
cols_with_nan = filtered_data.columns[filtered_data.isna().any()] 
nan_values = filtered_data[cols_with_nan].isna().sum() # numbers are as expected 

# set 'case number' column as index 
dataset = filtered_data.set_index('Case Number')

# STEP 2: check for duplicate rows 
print(dataset.duplicated().sum()) # no duplicates present 

# STEP 3: handle remaining missing values 
# Log reg and NN cannot handle NAN values 
# group-based mean imputation

# Replace columns with NaN with the mean values of the same class label 
dataset_fil = dataset.copy()
cols = ['BMI', 'HDL', 'Sys BP', 'OGTT']

for col in cols:
    dataset_fil[col] = dataset.groupby('Class Label(GDM /Non GDM)')[col] \
                              .transform(lambda x: x.fillna(x.mean()))
# check NAN values 
print(dataset_fil.isna().sum())

# STEP 4: assign variables 

y = dataset_fil['Class Label(GDM /Non GDM)']
x = dataset_fil.iloc[:,:-1]

#STEP 5: train test split (train = 70%) 
from sklearn.model_selection import train_test_split
x_train, x_temp, y_train, y_temp = train_test_split(x, y, random_state=42, test_size=0.30, stratify=y)

# assign test and validation sets (both 15%)
x_test, x_val, y_test, y_val = train_test_split(x_temp, y_temp, test_size=0.50, random_state=42, stratify=y_temp)

#%% Pipelines 
# STEP 6: model pipelines with feature scaling, class imbalance and model specific parameters
from sklearn.preprocessing import StandardScaler
from sklearn.pipeline import Pipeline
from sklearn.linear_model import LogisticRegression
from sklearn.ensemble import RandomForestClassifier
from xgboost import XGBClassifier
from sklearn.neural_network import MLPClassifier
from sklearn.model_selection import TunedThresholdClassifierCV
from sklearn.metrics import make_scorer, recall_score, precision_score, accuracy_score, classification_report
from sklearn.metrics import ConfusionMatrixDisplay
import seaborn as sns 
import shap 
from matplotlib import pyplot as plt

#%% Logistic Regression 

# Custom scorer: recall with minimum precision constraint
def recall_with_precision_constraint(y_true, y_pred, min_precision=0.9):
    precision = precision_score(y_true, y_pred)
    recall = recall_score(y_true, y_pred)
    
    # Penalise if precision is below the minimum
    if precision < min_precision:
        return 0.0
    return recall

# Make scorer
scorer = make_scorer(recall_with_precision_constraint)

# Threshold-tuned model
Log_reg_base = LogisticRegression(max_iter=100)
Log_reg_model = TunedThresholdClassifierCV(estimator=Log_reg_base, scoring=scorer)

log_reg_pipeline = Pipeline(steps=[
    ('standardscaler', StandardScaler()),
    ('logisticregression', Log_reg_model)])

log_reg_pipeline.fit(x_train, y_train)

log_predict = log_reg_pipeline.predict(x_test)
log_proba = log_reg_pipeline.predict_proba(x_test)[:,1] # probability of class 1 (GDM)

log_accuracy = accuracy_score(y_test, log_predict)
log_classification = classification_report(y_test, log_predict, output_dict=True)

print(log_accuracy)
print(log_classification)

# Threshold used
log_threshold = log_reg_pipeline.named_steps['logisticregression'].best_threshold_
print("Best threshold:", log_threshold)

# Number of iterations the underlying LogisticRegression used
print(log_reg_pipeline.named_steps['logisticregression'].estimator_.n_iter_) #14 

ConfusionMatrixDisplay.from_predictions(y_test, log_predict,
    display_labels=["No GDM", "GDM"],
    cmap="Blues")

plt.title("Confusion Matrix - Logistic Regression")
plt.show()


# plotting misclassified samples 
log_df = pd.DataFrame({
    'True Label': y_test,
    'Predicted Probability': log_proba,
    'Predicted Label': log_predict})

log_df['Misclassified'] = log_df['True Label'] != log_df['Predicted Label']
log_df['True Label'] = log_df['True Label'].map({0: 'No GDM', 1: 'GDM'})

plt.figure(figsize=(8,6))
sns.swarmplot(
    data=log_df,
    x='Predicted Probability',
    y='True Label',
    hue='Misclassified',
    palette={False: 'blue', True: 'red'},
    alpha=0.7)

plt.axvline(log_threshold, linestyle='--', label=f'Threshold = {log_threshold:.2f}')

plt.title('Logistic Regression Predicted Probabilities by True Class')
plt.ylabel('True Class')
plt.xlabel('Predicted Probability')

plt.legend(title='Misclassified')
plt.show()
