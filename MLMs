plt.plot(x_axis, val_loss, label='Validation')
# Mark best iteration (early stopping point)
best_iter = XG_model.best_iteration
best_score = val_loss[best_iter]

plt.axvline(best_iter, linestyle='--', label='Best Iteration')
plt.scatter(best_iter, best_score)

plt.legend()
plt.xlabel('Boosting Round')
plt.ylabel('Log Loss')
plt.title('XGBoost Learning Curve with Early Stopping')

plt.show()

